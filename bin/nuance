#!/usr/bin/env bash
# nuance — CLI usable from any shell (bash/zsh/fish/…).
#   nuance update     pull the checkout, then reload your Nushell
#   nuance help       this help
# Inside Nushell you can also call `nuance update` directly (built-in command).
set -euo pipefail

REPO_URL="https://github.com/sorinirimies/nuance.git"

info() { printf '\033[1;32m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!  \033[0m %s\n' "$*"; }

have() { command -v "$1" >/dev/null 2>&1; }

# Resolve the nuance checkout from the autoload symlink (needs `nu`).
repo_dir() {
  have nu || return 0
  local dir link
  dir="$(nu -n -c '$nu.user-autoload-dirs | get 0' 2>/dev/null || true)"
  [ -n "$dir" ] || return 0
  link="$dir/nushell-prompt.nu"
  [ -e "$link" ] || return 0
  # canonicalize (follows the symlink), then take its directory
  if have realpath; then dirname "$(realpath "$link")"
  elif have python3; then python3 -c 'import os,sys;print(os.path.dirname(os.path.realpath(sys.argv[1])))' "$link"
  else
    # bash fallback
    local t="$link"; while [ -L "$t" ]; do t="$(readlink "$t")"; done
    ( cd "$(dirname "$link")" && cd "$(dirname "$t")" && pwd )
  fi
}

usage() {
  cat <<'EOF'
nuance — themeable, git-aware Nushell prompt

  nuance update     pull the latest and print a reload hint
  nuance help       show this help

Inside Nushell, switch appearance with:
  theme [name] · prompt-style [name] · look [name] · theme-sync
EOF
}

cmd_update() {
  local dir; dir="$(repo_dir || true)"
  if [ -n "${dir:-}" ] && [ -d "$dir/.git" ]; then
    info "updating $dir …"
    git -C "$dir" pull --ff-only
    printf '\033[1;32m✓\033[0m updated — open a new shell (or run: exec nu)\n'
  else
    warn "no git checkout found (copy/bootstrap install) — re-run the bootstrap:"
    echo "  curl -fsSL https://raw.githubusercontent.com/sorinirimies/nuance/main/bootstrap.sh | bash"
  fi
}

case "${1:-help}" in
  update) cmd_update ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
